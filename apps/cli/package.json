{
  "name": "stackhealth",
  "version": "0.2.0",
  "description": "Score any public GitHub repo against the StackHealth open-formula benchmark — from your terminal.",
  "keywords": [
    "code-quality",
    "code-health",
    "benchmark",
    "github",
    "scorecard",
    "cli"
  ],
  "homepage": "https://stackhealth.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santosh3743/stackhealth.git",
    "directory": "apps/cli"
  },
  "license": "MIT",
  "author": "Santosh Jha",
  "type": "module",
  "bin": {
    "stackhealth": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/finalize.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
