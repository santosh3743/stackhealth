# Copy to .env.local for local dev. NEVER commit .env.local.

# --- Database ---
DATABASE_URL=postgresql+psycopg://stackhealth:stackhealth@localhost:5432/stackhealth

# --- Redis (queue + rate-limit) ---
REDIS_URL=redis://localhost:6379/0

# --- GitHub API (used by worker for repo metadata) ---
# Personal access token, scope: public_repo (read-only)
GITHUB_TOKEN=

# --- Cloudflare R2 (raw scan artifacts) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stackhealth-artifacts
R2_PUBLIC_URL=https://artifacts.stackhealth.dev

# --- Observability ---
SENTRY_DSN=

# --- Formula + limits ---
FORMULA_VERSION=v1.0
SCAN_WALL_CLOCK_TIMEOUT_SECONDS=300
CLONE_TIMEOUT_SECONDS=30
CLONE_SIZE_LIMIT_MB=500
RATE_LIMIT_SCANS_PER_IP_PER_HOUR=5

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:3000
