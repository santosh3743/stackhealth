# Copy to .env at the repo root and fill in.
# Compose reads this via --env-file .env.

# Your apex domain. The app will serve from `https://${DOMAIN}` and the API
# from `https://api.${DOMAIN}`. Point an A record for both at your VM's IP.
DOMAIN=stackhealth.example.com

# Email Let's Encrypt should use for cert renewals + expiry warnings.
ACME_EMAIL=you@example.com

# Generate a strong password: `openssl rand -base64 32`
POSTGRES_PASSWORD=changeme-please

# Personal access token (scope: public_repo, read-only). The worker uses
# this to lift GitHub's anonymous rate limit from 60/hr → 5000/hr.
GITHUB_TOKEN=

# Optional — error tracking.
SENTRY_DSN=
