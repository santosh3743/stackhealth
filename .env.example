# Root-level env defaults. Each app also has its own .env.example.
# Copy this to .env.local and fill in. NEVER commit .env.local.

# === Shared between web and api ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === API ===
DATABASE_URL=postgresql+psycopg://stackhealth:stackhealth@localhost:5432/stackhealth
REDIS_URL=redis://localhost:6379/0
GITHUB_TOKEN=ghp_replace_with_personal_access_token_scope_public_repo

# === Object storage (Cloudflare R2) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=stackhealth-artifacts
R2_PUBLIC_URL=https://artifacts.stackhealth.dev

# === Observability ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
PLAUSIBLE_DOMAIN=

# === Feature flags / config ===
FORMULA_VERSION=v1.0
SCAN_WALL_CLOCK_TIMEOUT_SECONDS=300
CLONE_TIMEOUT_SECONDS=30
CLONE_SIZE_LIMIT_MB=500
RATE_LIMIT_SCANS_PER_IP_PER_HOUR=5
